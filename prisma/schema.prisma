generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model account {
  id                String  @id
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              user    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model balance_freezes {
  id             String    @id
  userId         String
  amount         Decimal   @db.Decimal(18, 6)
  status         String    @default("pending")
  source         String?   @db.VarChar(64)
  taskId         String?
  requestId      String?
  idempotencyKey String?   @unique
  metadata       String?   @db.Text
  expiresAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @default(now())

  @@index([status])
  @@index([taskId])
  @@index([userId])
}

model balance_transactions {
  id              String   @id
  userId          String
  type            String
  amount          Decimal  @db.Decimal(18, 6)
  balanceAfter    Decimal  @db.Decimal(18, 6)
  description     String?  @db.Text
  relatedId       String?
  freezeId        String?
  operatorId      String?  @db.VarChar(64)
  externalOrderId String?  @db.VarChar(128)
  idempotencyKey  String?  @db.VarChar(128)
  projectId       String?  @db.VarChar(128)
  episodeId       String?  @db.VarChar(128)
  taskType        String?  @db.VarChar(64)
  billingMeta     String?  @db.Text
  createdAt       DateTime @default(now())

  @@unique([userId, type, idempotencyKey])
  @@index([createdAt])
  @@index([externalOrderId])
  @@index([freezeId])
  @@index([projectId])
  @@index([type])
  @@index([userId])
}

model character_appearances {
  id                         String                     @id
  characterId                String
  appearanceIndex            Int
  changeReason               String
  description                String?                    @db.Text
  descriptions               String?                    @db.Text
  imageUrl                   String?                    @db.Text
  imageUrls                  String?                    @db.Text
  selectedIndex              Int?
  bibleLocked                Boolean                    @default(false)
  bibleLockedAt              DateTime?
  createdAt                  DateTime                   @default(now())
  updatedAt                  DateTime                   @default(now())
  previousImageUrl           String?                    @db.Text
  previousImageUrls          String?                    @db.Text
  previousDescription        String?                    @db.Text
  previousDescriptions       String?                    @db.Text
  imageMediaId               String?
  novel_promotion_characters novel_promotion_characters @relation(fields: [characterId], references: [id], onDelete: Cascade)
  media_objects              media_objects?             @relation(fields: [imageMediaId], references: [id])

  @@unique([characterId, appearanceIndex])
  @@index([characterId])
  @@index([imageMediaId])
}

model character_relations {
  id                       String                   @id
  novelPromotionProjectId  String
  fromName                 String
  toName                   String
  relationType             String
  direction                String                   @default("unidirectional")
  description              String?                  @db.Text
  createdAt                DateTime                 @default(now())
  updatedAt                DateTime                 @default(now())
  novel_promotion_projects novel_promotion_projects @relation(fields: [novelPromotionProjectId], references: [id], onDelete: Cascade)

  @@unique([novelPromotionProjectId, fromName, toName])
  @@index([novelPromotionProjectId])
}

model global_asset_folders {
  id                String              @id
  userId            String
  name              String
  createdAt         DateTime            @default(now())
  updatedAt         DateTime
  user              user                @relation(fields: [userId], references: [id], onDelete: Cascade)
  global_characters global_characters[]
  global_locations  global_locations[]
  global_voices     global_voices[]

  @@index([userId])
}

model global_character_appearances {
  id                                                                             String            @id
  characterId                                                                    String
  appearanceIndex                                                                Int
  changeReason                                                                   String            @default("default")
  artStyle                                                                       String?
  description                                                                    String?           @db.Text
  descriptions                                                                   String?           @db.Text
  imageUrl                                                                       String?           @db.Text
  imageMediaId                                                                   String?
  imageUrls                                                                      String?           @db.Text
  selectedIndex                                                                  Int?
  previousImageUrl                                                               String?           @db.Text
  previousImageMediaId                                                           String?
  previousImageUrls                                                              String?           @db.Text
  previousDescription                                                            String?           @db.Text
  previousDescriptions                                                           String?           @db.Text
  createdAt                                                                      DateTime          @default(now())
  updatedAt                                                                      DateTime
  global_characters                                                              global_characters @relation(fields: [characterId], references: [id], onDelete: Cascade)
  media_objects_global_character_appearances_imageMediaIdTomedia_objects         media_objects?    @relation("global_character_appearances_imageMediaIdTomedia_objects", fields: [imageMediaId], references: [id])
  media_objects_global_character_appearances_previousImageMediaIdTomedia_objects media_objects?    @relation("global_character_appearances_previousImageMediaIdTomedia_objects", fields: [previousImageMediaId], references: [id])

  @@unique([characterId, appearanceIndex])
  @@index([characterId])
  @@index([imageMediaId])
  @@index([previousImageMediaId])
}

model global_characters {
  id                           String                         @id
  userId                       String
  folderId                     String?
  name                         String
  aliases                      String?                        @db.Text
  profileData                  String?                        @db.Text
  profileConfirmed             Boolean                        @default(false)
  voiceId                      String?
  voiceType                    String?
  customVoiceUrl               String?                        @db.Text
  customVoiceMediaId           String?
  globalVoiceId                String?
  createdAt                    DateTime                       @default(now())
  updatedAt                    DateTime
  global_character_appearances global_character_appearances[]
  media_objects                media_objects?                 @relation(fields: [customVoiceMediaId], references: [id])
  global_asset_folders         global_asset_folders?          @relation(fields: [folderId], references: [id])
  user                         user                           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([customVoiceMediaId])
  @@index([folderId])
  @@index([userId])
}

model global_location_images {
  id                                                                       String           @id
  locationId                                                               String
  imageIndex                                                               Int
  description                                                              String?          @db.Text
  availableSlots                                                           String?          @db.Text
  imageUrl                                                                 String?          @db.Text
  imageMediaId                                                             String?
  isSelected                                                               Boolean          @default(false)
  previousImageUrl                                                         String?          @db.Text
  previousImageMediaId                                                     String?
  previousDescription                                                      String?          @db.Text
  createdAt                                                                DateTime         @default(now())
  updatedAt                                                                DateTime
  media_objects_global_location_images_imageMediaIdTomedia_objects         media_objects?   @relation("global_location_images_imageMediaIdTomedia_objects", fields: [imageMediaId], references: [id])
  global_locations                                                         global_locations @relation(fields: [locationId], references: [id], onDelete: Cascade)
  media_objects_global_location_images_previousImageMediaIdTomedia_objects media_objects?   @relation("global_location_images_previousImageMediaIdTomedia_objects", fields: [previousImageMediaId], references: [id])

  @@unique([locationId, imageIndex])
  @@index([imageMediaId])
  @@index([locationId])
  @@index([previousImageMediaId])
}

model global_locations {
  id                     String                   @id
  userId                 String
  folderId               String?
  name                   String
  artStyle               String?
  summary                String?                  @db.Text
  assetKind              String                   @default("location")
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime
  global_location_images global_location_images[]
  global_asset_folders   global_asset_folders?    @relation(fields: [folderId], references: [id])
  user                   user                     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([folderId])
  @@index([userId])
}

model global_voices {
  id                   String                @id
  userId               String
  folderId             String?
  name                 String
  description          String?               @db.Text
  voiceId              String?
  voiceType            String                @default("qwen-designed")
  customVoiceUrl       String?               @db.Text
  customVoiceMediaId   String?
  voicePrompt          String?               @db.Text
  gender               String?
  language             String                @default("zh")
  createdAt            DateTime              @default(now())
  updatedAt            DateTime
  media_objects        media_objects?        @relation(fields: [customVoiceMediaId], references: [id])
  global_asset_folders global_asset_folders? @relation(fields: [folderId], references: [id])
  user                 user                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([customVoiceMediaId])
  @@index([folderId])
  @@index([userId])
}

model graph_artifacts {
  id           String     @id
  runId        String
  stepKey      String?
  artifactType String
  refId        String
  versionHash  String?
  payload      String?    @db.LongText
  createdAt    DateTime   @default(now())
  graph_runs   graph_runs @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@unique([runId, stepKey, artifactType, refId])
  @@index([artifactType, refId])
  @@index([runId])
  @@index([runId, stepKey])
}

model graph_checkpoints {
  id         String     @id
  runId      String
  nodeKey    String
  version    Int
  stateJson  String     @db.LongText
  stateBytes Int
  createdAt  DateTime   @default(now())
  graph_runs graph_runs @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@unique([runId, nodeKey, version])
  @@index([runId, createdAt])
}

model graph_events {
  id         BigInt     @id @default(autoincrement())
  runId      String
  projectId  String
  userId     String
  seq        Int
  eventType  String
  stepKey    String?
  attempt    Int?
  lane       String?
  payload    String?    @db.LongText
  createdAt  DateTime   @default(now())
  graph_runs graph_runs @relation(fields: [runId], references: [id], onDelete: Cascade)
  user       user       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([runId, seq])
  @@index([projectId, id])
  @@index([runId, id])
  @@index([userId, id])
}

model graph_runs {
  id                  String                @id
  userId              String
  projectId           String
  episodeId           String?
  workflowType        String
  taskType            String?
  taskId              String?               @unique
  targetType          String
  targetId            String
  status              String                @default("queued")
  input               String?               @db.LongText
  output              String?               @db.LongText
  errorCode           String?
  errorMessage        String?               @db.Text
  cancelRequestedAt   DateTime?
  leaseOwner          String?
  leaseExpiresAt      DateTime?
  heartbeatAt         DateTime?
  workflowVersion     Int                   @default(1)
  queuedAt            DateTime              @default(now())
  startedAt           DateTime?
  finishedAt          DateTime?
  lastSeq             Int                   @default(0)
  createdAt           DateTime              @default(now())
  updatedAt           DateTime
  graph_artifacts     graph_artifacts[]
  graph_checkpoints   graph_checkpoints[]
  graph_events        graph_events[]
  user                user                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  graph_step_attempts graph_step_attempts[]
  graph_steps         graph_steps[]

  @@index([leaseExpiresAt])
  @@index([projectId, status])
  @@index([targetType, targetId])
  @@index([taskId])
  @@index([userId, createdAt])
  @@index([workflowType, targetType, targetId, status])
}

model graph_step_attempts {
  id              String      @id
  runId           String
  stepKey         String
  attempt         Int
  status          String      @default("pending")
  provider        String?
  modelKey        String?
  inputHash       String?
  input           String?     @db.LongText
  outputText      String?     @db.Text
  outputReasoning String?     @db.Text
  usageJson       String?     @db.LongText
  errorCode       String?
  errorMessage    String?     @db.Text
  startedAt       DateTime?
  finishedAt      DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime
  graph_runs      graph_runs  @relation(fields: [runId], references: [id], onDelete: Cascade)
  graph_steps     graph_steps @relation(fields: [runId, stepKey], references: [runId, stepKey], onDelete: Cascade)

  @@unique([runId, stepKey, attempt])
  @@index([runId, createdAt])
  @@index([runId, stepKey])
}

model graph_steps {
  id                  String                @id
  runId               String
  stepKey             String
  stepTitle           String
  status              String                @default("pending")
  currentAttempt      Int                   @default(0)
  stepIndex           Int
  stepTotal           Int
  startedAt           DateTime?
  finishedAt          DateTime?
  lastErrorCode       String?
  lastErrorMessage    String?               @db.Text
  createdAt           DateTime              @default(now())
  updatedAt           DateTime
  graph_step_attempts graph_step_attempts[]
  graph_runs          graph_runs            @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@unique([runId, stepKey])
  @@index([runId, status])
  @@index([runId, stepIndex])
}

model legacy_media_refs_backup {
  id          String   @id
  runId       String
  tableName   String
  rowId       String
  fieldName   String
  legacyValue String   @db.Text
  checksum    String
  createdAt   DateTime @default(now())

  @@index([runId])
  @@index([tableName, fieldName])
}

model location_images {
  id                                                                                   String                      @id
  locationId                                                                           String
  imageIndex                                                                           Int
  description                                                                          String?                     @db.Text
  availableSlots                                                                       String?                     @db.Text
  imageUrl                                                                             String?                     @db.Text
  isSelected                                                                           Boolean                     @default(false)
  createdAt                                                                            DateTime                    @default(now())
  updatedAt                                                                            DateTime                    @default(now())
  previousImageUrl                                                                     String?                     @db.Text
  previousDescription                                                                  String?                     @db.Text
  imageMediaId                                                                         String?
  media_objects                                                                        media_objects?              @relation(fields: [imageMediaId], references: [id])
  novel_promotion_locations_location_images_locationIdTonovel_promotion_locations      novel_promotion_locations   @relation("location_images_locationIdTonovel_promotion_locations", fields: [locationId], references: [id], onDelete: Cascade)
  novel_promotion_locations_novel_promotion_locations_selectedImageIdTolocation_images novel_promotion_locations[] @relation("novel_promotion_locations_selectedImageIdTolocation_images")

  @@unique([locationId, imageIndex])
  @@index([imageMediaId])
  @@index([locationId])
}

model media_objects {
  id                                                                                            String                         @id
  publicId                                                                                      String                         @unique
  storageKey                                                                                    String                         @unique @db.VarChar(512)
  sha256                                                                                        String?
  mimeType                                                                                      String?
  sizeBytes                                                                                     BigInt?
  width                                                                                         Int?
  height                                                                                        Int?
  durationMs                                                                                    Int?
  createdAt                                                                                     DateTime                       @default(now())
  updatedAt                                                                                     DateTime                       @default(now())
  character_appearances                                                                         character_appearances[]
  global_character_appearances_global_character_appearances_imageMediaIdTomedia_objects         global_character_appearances[] @relation("global_character_appearances_imageMediaIdTomedia_objects")
  global_character_appearances_global_character_appearances_previousImageMediaIdTomedia_objects global_character_appearances[] @relation("global_character_appearances_previousImageMediaIdTomedia_objects")
  global_characters                                                                             global_characters[]
  global_location_images_global_location_images_imageMediaIdTomedia_objects                     global_location_images[]       @relation("global_location_images_imageMediaIdTomedia_objects")
  global_location_images_global_location_images_previousImageMediaIdTomedia_objects             global_location_images[]       @relation("global_location_images_previousImageMediaIdTomedia_objects")
  global_voices                                                                                 global_voices[]
  location_images                                                                               location_images[]
  novel_promotion_characters                                                                    novel_promotion_characters[]
  novel_promotion_episodes                                                                      novel_promotion_episodes[]
  novel_promotion_panels_novel_promotion_panels_imageMediaIdTomedia_objects                     novel_promotion_panels[]       @relation("novel_promotion_panels_imageMediaIdTomedia_objects")
  novel_promotion_panels_novel_promotion_panels_lipSyncVideoMediaIdTomedia_objects              novel_promotion_panels[]       @relation("novel_promotion_panels_lipSyncVideoMediaIdTomedia_objects")
  novel_promotion_panels_novel_promotion_panels_previousImageMediaIdTomedia_objects             novel_promotion_panels[]       @relation("novel_promotion_panels_previousImageMediaIdTomedia_objects")
  novel_promotion_panels_novel_promotion_panels_sketchImageMediaIdTomedia_objects               novel_promotion_panels[]       @relation("novel_promotion_panels_sketchImageMediaIdTomedia_objects")
  novel_promotion_panels_novel_promotion_panels_videoMediaIdTomedia_objects                     novel_promotion_panels[]       @relation("novel_promotion_panels_videoMediaIdTomedia_objects")
  novel_promotion_shots                                                                         novel_promotion_shots[]
  novel_promotion_voice_lines                                                                   novel_promotion_voice_lines[]
  supplementary_panels                                                                          supplementary_panels[]
  voice_presets                                                                                 voice_presets[]

  @@index([createdAt])
}

model novel_promotion_characters {
  id                       String                   @id
  novelPromotionProjectId  String
  name                     String
  aliases                  String?                  @db.Text
  createdAt                DateTime                 @default(now())
  updatedAt                DateTime                 @default(now())
  customVoiceUrl           String?                  @db.Text
  customVoiceMediaId       String?
  voiceId                  String?
  voiceType                String?
  profileData              String?                  @db.Text
  profileConfirmed         Boolean                  @default(false)
  introduction             String?                  @db.Text
  sourceGlobalCharacterId  String?
  character_appearances    character_appearances[]
  media_objects            media_objects?           @relation(fields: [customVoiceMediaId], references: [id])
  novel_promotion_projects novel_promotion_projects @relation(fields: [novelPromotionProjectId], references: [id], onDelete: Cascade)

  @@index([customVoiceMediaId])
  @@index([novelPromotionProjectId])
}

model novel_promotion_clips {
  id                          String                       @id
  episodeId                   String
  start                       Int?
  end                         Int?
  duration                    Int?
  summary                     String                       @db.Text
  location                    String?                      @db.Text
  content                     String                       @db.Text
  createdAt                   DateTime                     @default(now())
  updatedAt                   DateTime                     @default(now())
  characters                  String?                      @db.Text
  props                       String?                      @db.Text
  endText                     String?                      @db.Text
  shotCount                   Int?
  startText                   String?                      @db.Text
  screenplay                  String?                      @db.Text
  novel_promotion_episodes    novel_promotion_episodes     @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  novel_promotion_shots       novel_promotion_shots[]
  novel_promotion_storyboards novel_promotion_storyboards?

  @@index([episodeId])
}

model novel_promotion_episodes {
  id                          String                        @id
  novelPromotionProjectId     String
  episodeNumber               Int
  name                        String
  description                 String?                       @db.Text
  novelText                   String?                       @db.Text
  audioUrl                    String?                       @db.Text
  audioMediaId                String?
  srtContent                  String?                       @db.Text
  createdAt                   DateTime                      @default(now())
  updatedAt                   DateTime                      @default(now())
  speakerVoices               String?                       @db.Text
  novel_promotion_clips       novel_promotion_clips[]
  media_objects               media_objects?                @relation(fields: [audioMediaId], references: [id])
  novel_promotion_projects    novel_promotion_projects      @relation(fields: [novelPromotionProjectId], references: [id], onDelete: Cascade)
  novel_promotion_shots       novel_promotion_shots[]
  novel_promotion_storyboards novel_promotion_storyboards[]
  novel_promotion_voice_lines novel_promotion_voice_lines[]
  video_editor_projects       video_editor_projects?

  @@unique([novelPromotionProjectId, episodeNumber])
  @@index([audioMediaId])
  @@index([novelPromotionProjectId])
}

model novel_promotion_locations {
  id                                                                         String                   @id
  novelPromotionProjectId                                                    String
  name                                                                       String
  summary                                                                    String?                  @db.Text
  assetKind                                                                  String                   @default("location")
  createdAt                                                                  DateTime                 @default(now())
  updatedAt                                                                  DateTime                 @default(now())
  sourceGlobalLocationId                                                     String?
  selectedImageId                                                            String?
  location_images_location_images_locationIdTonovel_promotion_locations      location_images[]        @relation("location_images_locationIdTonovel_promotion_locations")
  novel_promotion_projects                                                   novel_promotion_projects @relation(fields: [novelPromotionProjectId], references: [id], onDelete: Cascade)
  location_images_novel_promotion_locations_selectedImageIdTolocation_images location_images?         @relation("novel_promotion_locations_selectedImageIdTolocation_images", fields: [selectedImageId], references: [id])

  @@index([novelPromotionProjectId])
  @@index([selectedImageId], map: "novel_promotion_locations_selectedImageId_fkey")
}

model novel_promotion_panels {
  id                                                                       String                        @id
  storyboardId                                                             String
  panelIndex                                                               Int
  panelNumber                                                              Int?
  shotType                                                                 String?                       @db.Text
  cameraMove                                                               String?                       @db.Text
  description                                                              String?                       @db.Text
  location                                                                 String?                       @db.Text
  characters                                                               String?                       @db.Text
  props                                                                    String?                       @db.Text
  srtSegment                                                               String?                       @db.Text
  srtStart                                                                 Float?
  srtEnd                                                                   Float?
  duration                                                                 Float?
  imagePrompt                                                              String?                       @db.Text
  imageUrl                                                                 String?                       @db.Text
  imageMediaId                                                             String?
  imageHistory                                                             String?                       @db.Text
  videoPrompt                                                              String?                       @db.Text
  firstLastFramePrompt                                                     String?                       @db.Text
  videoUrl                                                                 String?                       @db.Text
  videoGenerationMode                                                      String?                       @db.Text
  videoMediaId                                                             String?
  createdAt                                                                DateTime                      @default(now())
  updatedAt                                                                DateTime                      @default(now())
  sceneType                                                                String?
  candidateImages                                                          String?                       @db.Text
  linkedToNextPanel                                                        Boolean                       @default(false)
  lipSyncTaskId                                                            String?
  lipSyncVideoUrl                                                          String?
  lipSyncVideoMediaId                                                      String?
  sketchImageUrl                                                           String?                       @db.Text
  sketchImageMediaId                                                       String?
  photographyRules                                                         String?                       @db.Text
  actingNotes                                                              String?                       @db.Text
  previousImageUrl                                                         String?                       @db.Text
  previousImageMediaId                                                     String?
  media_objects_novel_promotion_panels_imageMediaIdTomedia_objects         media_objects?                @relation("novel_promotion_panels_imageMediaIdTomedia_objects", fields: [imageMediaId], references: [id])
  media_objects_novel_promotion_panels_lipSyncVideoMediaIdTomedia_objects  media_objects?                @relation("novel_promotion_panels_lipSyncVideoMediaIdTomedia_objects", fields: [lipSyncVideoMediaId], references: [id])
  media_objects_novel_promotion_panels_previousImageMediaIdTomedia_objects media_objects?                @relation("novel_promotion_panels_previousImageMediaIdTomedia_objects", fields: [previousImageMediaId], references: [id])
  media_objects_novel_promotion_panels_sketchImageMediaIdTomedia_objects   media_objects?                @relation("novel_promotion_panels_sketchImageMediaIdTomedia_objects", fields: [sketchImageMediaId], references: [id])
  novel_promotion_storyboards                                              novel_promotion_storyboards   @relation(fields: [storyboardId], references: [id], onDelete: Cascade)
  media_objects_novel_promotion_panels_videoMediaIdTomedia_objects         media_objects?                @relation("novel_promotion_panels_videoMediaIdTomedia_objects", fields: [videoMediaId], references: [id])
  novel_promotion_voice_lines                                              novel_promotion_voice_lines[]

  @@unique([storyboardId, panelIndex])
  @@index([imageMediaId])
  @@index([lipSyncVideoMediaId])
  @@index([previousImageMediaId])
  @@index([sketchImageMediaId])
  @@index([storyboardId])
  @@index([videoMediaId])
}

model novel_promotion_projects {
  id                         String                       @id
  projectId                  String                       @unique
  createdAt                  DateTime                     @default(now())
  updatedAt                  DateTime                     @default(now())
  analysisModel              String?
  imageModel                 String?
  videoModel                 String?
  audioModel                 String?
  videoRatio                 String                       @default("9:16")
  ttsRate                    String                       @default("+50%")
  globalAssetText            String?                      @db.Text
  artStyle                   String                       @default("american-comic")
  artStylePrompt             String?                      @db.Text
  colorGradePreset           String                       @default("auto")
  targetPlatform             String                       @default("douyin")
  characterModel             String?
  locationModel              String?
  storyboardModel            String?
  editModel                  String?
  videoResolution            String                       @default("720p")
  capabilityOverrides        String?                      @db.Text
  workflowMode               String                       @default("srt")
  lastEpisodeId              String?
  imageResolution            String                       @default("2K")
  importStatus               String?
  screenplayTone             String                       @default("auto")
  storyRewriteMode           String                       @default("none")
  character_relations        character_relations[]
  novel_promotion_characters novel_promotion_characters[]
  novel_promotion_episodes   novel_promotion_episodes[]
  novel_promotion_locations  novel_promotion_locations[]
  projects                   projects                     @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model novel_promotion_shots {
  id                       String                   @id
  episodeId                String
  clipId                   String?
  shotId                   String
  srtStart                 Int
  srtEnd                   Int
  srtDuration              Float
  sequence                 String?                  @db.Text
  locations                String?                  @db.Text
  characters               String?                  @db.Text
  plot                     String?                  @db.Text
  imagePrompt              String?                  @db.Text
  scale                    String?                  @db.Text
  module                   String?                  @db.Text
  focus                    String?                  @db.Text
  zhSummarize              String?                  @db.Text
  imageUrl                 String?                  @db.Text
  imageMediaId             String?
  createdAt                DateTime                 @default(now())
  updatedAt                DateTime                 @default(now())
  pov                      String?                  @db.Text
  novel_promotion_clips    novel_promotion_clips?   @relation(fields: [clipId], references: [id], onDelete: Cascade)
  novel_promotion_episodes novel_promotion_episodes @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  media_objects            media_objects?           @relation(fields: [imageMediaId], references: [id])

  @@index([clipId])
  @@index([episodeId])
  @@index([imageMediaId])
  @@index([shotId])
}

model novel_promotion_storyboards {
  id                       String                   @id
  episodeId                String
  clipId                   String                   @unique
  storyboardImageUrl       String?                  @db.Text
  createdAt                DateTime                 @default(now())
  updatedAt                DateTime                 @default(now())
  panelCount               Int                      @default(9)
  storyboardTextJson       String?                  @db.Text
  imageHistory             String?                  @db.Text
  candidateImages          String?                  @db.Text
  lastError                String?
  photographyPlan          String?                  @db.Text
  novel_promotion_panels   novel_promotion_panels[]
  novel_promotion_clips    novel_promotion_clips    @relation(fields: [clipId], references: [id], onDelete: Cascade)
  novel_promotion_episodes novel_promotion_episodes @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  supplementary_panels     supplementary_panels[]

  @@index([clipId])
  @@index([episodeId])
}

model novel_promotion_voice_lines {
  id                       String                   @id
  episodeId                String
  lineIndex                Int
  speaker                  String
  content                  String                   @db.Text
  voicePresetId            String?
  audioUrl                 String?                  @db.Text
  audioMediaId             String?
  createdAt                DateTime                 @default(now())
  updatedAt                DateTime                 @default(now())
  emotionPrompt            String?                  @db.Text
  emotionStrength          Float?                   @default(0.4)
  matchedPanelIndex        Int?
  matchedStoryboardId      String?
  audioDuration            Int?
  matchedPanelId           String?
  media_objects            media_objects?           @relation(fields: [audioMediaId], references: [id])
  novel_promotion_episodes novel_promotion_episodes @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  novel_promotion_panels   novel_promotion_panels?  @relation(fields: [matchedPanelId], references: [id])

  @@unique([episodeId, lineIndex])
  @@index([audioMediaId])
  @@index([episodeId])
  @@index([matchedPanelId])
}

model projects {
  id                       String                    @id
  name                     String
  description              String?                   @db.Text
  userId                   String
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @default(now())
  lastAccessedAt           DateTime?
  novel_promotion_projects novel_promotion_projects?
  user                     user                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  usage_costs              usage_costs[]

  @@index([userId])
}

model session {
  id           String   @id
  sessionToken String   @unique(map: "Session_sessionToken_key")
  userId       String
  expires      DateTime
  user         user     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model supplementary_panels {
  id                          String                      @id
  storyboardId                String
  sourceType                  String
  sourcePanelId               String?
  description                 String?                     @db.Text
  imagePrompt                 String?                     @db.Text
  imageUrl                    String?                     @db.Text
  imageMediaId                String?
  characters                  String?                     @db.Text
  location                    String?                     @db.Text
  createdAt                   DateTime                    @default(now())
  updatedAt                   DateTime                    @default(now())
  media_objects               media_objects?              @relation(fields: [imageMediaId], references: [id])
  novel_promotion_storyboards novel_promotion_storyboards @relation(fields: [storyboardId], references: [id], onDelete: Cascade)

  @@index([imageMediaId])
  @@index([storyboardId])
}

model task_events {
  id        Int      @id @default(autoincrement())
  taskId    String
  projectId String
  userId    String
  eventType String
  payload   String?  @db.LongText
  createdAt DateTime @default(now())
  tasks     tasks    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([projectId, id])
  @@index([taskId])
  @@index([userId])
}

model tasks {
  id               String        @id
  userId           String
  projectId        String
  episodeId        String?
  type             String
  targetType       String
  targetId         String
  status           String        @default("queued")
  progress         Int           @default(0)
  attempt          Int           @default(0)
  maxAttempts      Int           @default(5)
  priority         Int           @default(0)
  dedupeKey        String?       @unique
  externalId       String?
  payload          String?       @db.LongText
  result           String?       @db.LongText
  errorCode        String?
  errorMessage     String?       @db.Text
  billingInfo      String?       @db.LongText
  billedAt         DateTime?
  queuedAt         DateTime      @default(now())
  startedAt        DateTime?
  finishedAt       DateTime?
  heartbeatAt      DateTime?
  enqueuedAt       DateTime?
  enqueueAttempts  Int           @default(0)
  lastEnqueueError String?       @db.Text
  createdAt        DateTime      @default(now())
  updatedAt        DateTime
  task_events      task_events[]
  user             user          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([heartbeatAt])
  @@index([projectId])
  @@index([status])
  @@index([targetType, targetId])
  @@index([type])
  @@index([userId])
}

model usage_costs {
  id        String   @id
  projectId String
  userId    String
  apiType   String
  model     String
  action    String
  quantity  Int
  unit      String
  cost      Decimal  @db.Decimal(18, 6)
  metadata  String?  @db.Text
  createdAt DateTime @default(now())
  projects  projects @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([apiType])
  @@index([createdAt])
  @@index([projectId])
  @@index([userId])
}

model user {
  id                   String                 @id
  name                 String                 @unique(map: "User_name_key")
  email                String?
  emailVerified        DateTime?
  image                String?
  password             String?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @default(now())
  account              account[]
  global_asset_folders global_asset_folders[]
  global_characters    global_characters[]
  global_locations     global_locations[]
  global_voices        global_voices[]
  graph_events         graph_events[]
  graph_runs           graph_runs[]
  projects             projects[]
  session              session[]
  task_events          task_events[]
  tasks                tasks[]
  usage_costs          usage_costs[]
  user_balances        user_balances?
  user_preferences     user_preferences?
}

model user_balances {
  id           String   @id
  userId       String   @unique
  balance      Decimal  @default(0.000000) @db.Decimal(18, 6)
  frozenAmount Decimal  @default(0.000000) @db.Decimal(18, 6)
  totalSpent   Decimal  @default(0.000000) @db.Decimal(18, 6)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now())
  user         user     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model user_preferences {
  id                  String   @id
  userId              String   @unique
  analysisModel       String?
  characterModel      String?
  locationModel       String?
  storyboardModel     String?
  editModel           String?
  videoModel          String?
  audioModel          String?
  lipSyncModel        String?
  voiceDesignModel    String?
  analysisConcurrency Int?
  imageConcurrency    Int?
  videoConcurrency    Int?
  videoRatio          String   @default("9:16")
  videoResolution     String   @default("720p")
  artStyle            String   @default("american-comic")
  ttsRate             String   @default("+50%")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @default(now())
  imageResolution     String   @default("2K")
  capabilityDefaults  String?  @db.Text
  llmBaseUrl          String?  @default("https://openrouter.ai/api/v1")
  llmApiKey           String?  @db.Text
  falApiKey           String?  @db.Text
  googleAiKey         String?  @db.Text
  arkApiKey           String?  @db.Text
  qwenApiKey          String?  @db.Text
  customModels        String?  @db.Text
  customProviders     String?  @db.Text
  user                user     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model verificationtoken {
  identifier String
  token      String   @unique(map: "VerificationToken_token_key")
  expires    DateTime

  @@unique([identifier, token])
}

model video_editor_projects {
  id                       String                   @id
  episodeId                String                   @unique
  projectData              String                   @db.Text
  renderStatus             String?
  renderTaskId             String?
  outputUrl                String?                  @db.Text
  createdAt                DateTime                 @default(now())
  updatedAt                DateTime                 @default(now())
  novel_promotion_episodes novel_promotion_episodes @relation(fields: [episodeId], references: [id], onDelete: Cascade)
}

model voice_presets {
  id            String         @id
  name          String
  audioUrl      String         @db.Text
  audioMediaId  String?
  description   String?        @db.Text
  gender        String?
  isSystem      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  media_objects media_objects? @relation(fields: [audioMediaId], references: [id])

  @@index([audioMediaId])
}
